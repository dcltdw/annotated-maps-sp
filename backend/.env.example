DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DATABASE_URL=postgis://annotated_maps:localdev@localhost:5432/annotated_maps
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173
GIT_SHA=dev
# macOS only — set to the GDAL dylib path when the installed version is
# newer than Django's auto-probe list (e.g. Homebrew gdal 3.10+).
# Linux/Docker: leave unset.
# GDAL_LIBRARY_PATH=/usr/local/lib/libgdal.dylib
